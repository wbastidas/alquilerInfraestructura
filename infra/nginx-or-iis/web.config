<!--
  Configuracion de IIS para SGAIE (§3.3 de la especificacion tecnica):
  sirve el frontend estatico compilado (frontend/dist) y reenvia /api/* al
  backend FastAPI/Uvicorn via ARR (Application Request Routing) + URL Rewrite.

  Requisitos en el servidor IIS:
    - Modulo "Application Request Routing" (ARR) instalado.
    - Modulo "URL Rewrite" instalado.
    - En IIS Manager > Server > Application Request Routing Cache > Server
      Proxy Settings: habilitar "Enable proxy".
    - Sitio con binding HTTPS (certificado institucional) en el puerto 443;
      el binding HTTP 80 solo debe existir para la regla de redireccion abajo.

  Colocar este archivo en la raiz del sitio IIS (el webroot publicado por
  infra/windows/publicar-frontend.ps1, p. ej. C:\inetpub\sgaie).
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. Forzar HTTPS: cualquier peticion HTTP se redirige a HTTPS. -->
        <rule name="Forzar HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 2. Reenviar /api/* al backend Uvicorn local (reverse proxy via ARR). -->
        <rule name="API hacia backend FastAPI" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/api/{R:1}" />
        </rule>

        <!-- 3. SPA fallback: cualquier ruta de frontend que no sea un archivo
             estatico existente se resuelve contra index.html (React Router). -->
        <rule name="SPA fallback a index.html" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Cabeceras de seguridad complementarias a las que ya emite el backend
         (app/middlewares/security_headers.py) para los activos estaticos. -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>
  </system.webServer>
</configuration>
