# Copiar a .env y ajustar valores. NUNCA versionar el .env real.
# En Windows Server, proteger este archivo con ACL restrictivas (solo cuenta de servicio).

ENTORNO=desarrollo
DEBUG=true

# Base de datos
DATABASE_URL=mysql+pymysql://sgaie:sgaie_dev@localhost:3306/sgaie

# JWT
JWT_SECRET_KEY=cambiar-esta-clave-por-una-aleatoria-de-al-menos-64-caracteres
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTOS=15
JWT_REFRESH_TOKEN_DIAS=7

# Clave maestra de cifrado AES-256 para campos sensibles (32 bytes, base64).
# Generar con: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AES_MASTER_KEY=cambiar-por-clave-base64-de-32-bytes

# CORS - orígenes explícitos separados por coma (sin "*" en producción)
CORS_ORIGENS=http://localhost:5173

# LDAP / Active Directory (funcionarios CNEL EP)
# TODO: confirmar con cliente la estructura exacta de OU/grupos del dominio institucional
LDAP_SERVIDOR=ldap://dominio.cnel.local
LDAP_BASE_DN=DC=cnel,DC=local
LDAP_BIND_USUARIO_DOMINIO=cnel.local
LDAP_USAR_SSL=false

# Rate limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=100/minute

# Almacenamiento de documentos (fuera del webroot)
ALMACENAMIENTO_DOCUMENTOS_DIR=./uploads
TAMANO_MAXIMO_ARCHIVO_MB=200

# Tasa activa referencial BCE para intereses por mora (parametrizable)
# TODO: confirmar con cliente - valor referencial inicial
TASA_INTERES_MORA_ANUAL=0.1671
